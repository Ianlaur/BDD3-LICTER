# =============================================================================
# BDD3-LICTER — Environment Variables
# =============================================================================
# Copy this file to src/zara/config/.env and fill in your real values.
# NEVER commit src/zara/config/.env to version control.
#
#   cp src/zara/config/.env.example src/zara/config/.env
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI API
# https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default model for analysis agents (can be overridden per-agent)
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_COMEX=gpt-4o

# -----------------------------------------------------------------------------
# Supabase
# https://supabase.com/dashboard/project/<your-project>/settings/api
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxx

# Supabase direct DB connection (for psql / migrations)
# Found at: Settings → Database → Connection string → URI
SUPABASE_DB_URL=postgresql://postgres:<password>@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Apify
# https://console.apify.com/account/integrations
# -----------------------------------------------------------------------------
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# N8N (if self-hosted)
# -----------------------------------------------------------------------------
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_KEY=

# -----------------------------------------------------------------------------
# Notifications (optional)
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# App settings
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development   # development | production
